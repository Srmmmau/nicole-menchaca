---
import Logo from '@/components/ui/Logo.astro';
import { emailHref, instagramUrl, agencyUrl } from '@/lib/contact';
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;

const links = [
  { href: '#trabajo', label: copy.nav.work },
  { href: '#sobre-mi', label: copy.nav.about },
  { href: '#clientes', label: copy.nav.clients },
];
---

<footer class="border-t border-line/20 py-14">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 md:grid-cols-3">
    <div>
      <Logo variant="inline" class="text-base text-ink" />
      <p class="mt-3 max-w-xs text-sm text-ink-muted">{copy.hero.subtitle}</p>
    </div>

    <div>
      <h3 class="font-display text-sm uppercase tracking-wide text-ink-subtle">{copy.nav.work}</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {links.map((link) => (
          <li><a href={link.href} class="text-ink/80 hover:text-ink">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm uppercase tracking-wide text-ink-subtle">{copy.nav.contact}</h3>
      <ul class="mt-3 space-y-2 text-sm text-ink/80">
        <li><a href={emailHref()} class="hover:text-ink">{import.meta.env.PUBLIC_CONTACT_EMAIL}</a></li>
        <li><a href={instagramUrl()} target="_blank" rel="noopener noreferrer" class="hover:text-ink">Instagram</a></li>
        <li><a href={agencyUrl()} target="_blank" rel="noopener noreferrer" class="hover:text-ink">{copy.contact.agencyLabel}: MOM</a></li>
      </ul>
    </div>
  </div>

  <div class="mx-auto mt-10 max-w-6xl px-4 text-xs text-ink-subtle sm:px-6">
    © {new Date().getFullYear()} Nicole Menchaca. {copy.footer.rights}
  </div>
</footer>

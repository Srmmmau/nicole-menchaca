---
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<section id="clientes" class="border-t border-line/20 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <h2 class="font-display text-4xl font-light sm:text-5xl">{copy.clients.heading}</h2>
    <p class="mx-auto mt-3 max-w-xl text-ink-muted">{copy.clients.subheading}</p>

    <ul class="mx-auto mt-10 flex max-w-3xl flex-wrap justify-center gap-x-10 gap-y-4">
      {copy.clients.names.map((name) => (
        <li class="font-display text-2xl text-ink/80 sm:text-3xl">{name}</li>
      ))}
    </ul>
  </div>
</section>

---
import { Image } from 'astro:assets';
import portrait from '@/assets/portfolio/about-portrait.png';
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<section id="sobre-mi" class="py-20 sm:py-28">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 md:grid-cols-2 md:items-center md:gap-16">
    <div class="overflow-hidden rounded-sm">
      <Image
        src={portrait}
        alt="Retrato de Nicole Menchaca"
        class="w-full object-cover"
        widths={[480, 720, 960]}
        sizes="(min-width: 768px) 45vw, 100vw"
      />
    </div>
    <div>
      <h2 class="font-display text-4xl font-light sm:text-5xl">{copy.about.heading}</h2>
      <p class="mt-2 text-sm uppercase tracking-wide text-ink-subtle">{copy.about.role}</p>
      <div class="mt-6 space-y-4 text-ink-muted">
        {copy.about.body.map((paragraph) => (
          <p class="text-balance-pretty">{paragraph}</p>
        ))}
      </div>
    </div>
  </div>
</section>

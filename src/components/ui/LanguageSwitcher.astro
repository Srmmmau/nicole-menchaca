---
import { languages, alternateLangUrl, type Lang } from '@/lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const other: Lang = lang === 'es' ? 'en' : 'es';
const href = alternateLangUrl(Astro.url, other);
---

<a
  href={href}
  class="rounded-full border border-line/40 px-3 py-1.5 text-xs uppercase tracking-wide text-ink-muted transition hover:border-ink hover:text-ink"
>
  {languages[other]}
</a>

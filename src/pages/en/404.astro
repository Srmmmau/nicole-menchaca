---
import BaseLayout from '@/components/layout/BaseLayout.astro';
---

<BaseLayout lang="en" title="Page not found — Nicole Menchaca" description="The page you're looking for doesn't exist.">
  <main class="flex min-h-dvh flex-col items-center justify-center gap-4 px-4 text-center">
    <h1 class="font-display text-5xl">404</h1>
    <p class="text-ink-muted">We couldn't find this page.</p>
    <a href="/en/" class="mt-2 text-sm uppercase tracking-wide text-ink underline underline-offset-4 hover:text-ink-muted">
      Back to home
    </a>
  </main>
</BaseLayout>

---
import BaseLayout from '@/components/layout/BaseLayout.astro';
---

<BaseLayout lang="es" title="Página no encontrada — Nicole Menchaca" description="La página que buscas no existe.">
  <main class="flex min-h-dvh flex-col items-center justify-center gap-4 px-4 text-center">
    <h1 class="font-display text-5xl">404</h1>
    <p class="text-ink-muted">No encontramos esta página.</p>
    <a href="/es/" class="mt-2 text-sm uppercase tracking-wide text-ink underline underline-offset-4 hover:text-ink-muted">
      Volver al inicio
    </a>
  </main>
</BaseLayout>
